    "html_format": "<div class=\"document-view-wrapper\">\n<style>\n.html-preview * {font-family: Times New Roman; font-size: 12pt;}\n.html-preview a.NoteRef {text-decoration: none;}\n.html-preview table td {vertical-align: top;}\n.html-preview table {width: 100%;}\n.html-preview p {white-space: pre-wrap;}\n.html-preview .leading {width: 4px; display: inline-block;}\n.html-preview hr {height: 1px; padding: 0; margin: 1em 0; border: 0; border-top: 1px solid #CCC;}\n.html-preview .Normal {className: Normal; margin-bottom: 8pt;}\n.html-preview .ListParagraph {font-family: 'Times New Roman';}\n.html-preview .ConsPlusNonformat {font-family: 'Courier New'; font-size: 10pt;}\n.html-preview .TableGrid td {border: 1px solid #000;}\n</style>\n<div class=\"html-preview\">\n<style>.html-preview{width: 762px}</style><style>.html-preview{margin-top: 76px}</style><style>.html-preview{margin-bottom: 32px}</style><style>.html-preview{padding-left: 81px}</style><style>.html-preview{padding-right: 57px}</style><table>\n<tr>\n<td 0=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 0=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Фуқаролик ишлари бўйича </span><span class=\"structures structure-2\" style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">{#2}Ариза берилган фуқаролик суди номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> судига</span></p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар: </span><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#6}Даъвогарнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">да яшовчи</span></p>\n</td>\n</tr>\n<tr>\n<td 2=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 2=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#7}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n</tr>\n<tr>\n<td 3=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 3=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Телефон: </span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#8}Даъвогарнинг телефон рақами</span></p>\n</td>\n</tr>\n<tr>\n<td 4=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 4=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Электрон почта манзили: </span><span class=\"structures structure-9\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#9}Даъвогарнинг электрон манзили</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p style=\"text-align: center; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Д<span class=\"leading\"></span>А Ъ В О <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>А Р И З А</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">(Боланинг мол-мулкини қайтариш юзасидан)</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; margin-bottom: 0pt; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Мен турмуш ўртоғим </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#11} Даъвогар турмуш ўртоғи Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> билан </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> </span><span class=\"structures structure-12\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#12} Даъвогар ва жавобгар турмуш қурган йили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> йилда турмуш қуриб </span><span class=\"structures structure-13\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#13}Даъвогар ва жавобгарнинг бирга яшаган йили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> <span class=\"leading\"></span>йил давомида бирга яшаганмиз. </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> </span><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#14}Даъвогар ва жавобгарнинг қонуний ажрашган йили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">йилда биз қонуний никоҳимизни суд орқали бекор қилдик ва суд ҳал қилув қарорига кўра фарзандим </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> </span><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#15}Фарзандининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> мен билан қолди. Аммо турмуш ўртоғим </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#11} Даъвогар турмуш ўртоғи Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">фарзандимга тегишли бўлган </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#16}Фарзандига тегишли бўлган буюм ва мол-мулк</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">лар ҳамда тегишли мол-мулкларни бизга бермасдан келмоқда.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Ўзбекистон Республикаси Оила кодексининг 27-моддасига кўра Вояга етмаган болалар эҳтиёжини қондириш учун олинган буюмлар (кийим-бош, пойабзал, мактаб ва спорт жиҳозлари, мусиқа асбоблари, болалар кутубхонаси ва бошқалар) бўлинмайди ҳамда болалар эр ва хотиндан қайси бири билан яшаса, унга компенсациясиз берилиши кўрсатилган.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Юқоридаги қоидага ва бошқа қонун ҳужжатларига асосланиб,</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">СЎРАЙМАН:</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#17}Фарзанди туғилган сана</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">да туғилган </span><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#15}Фарзандининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">исмли фарзандимга </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">тегишли бўлган </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#16}Фарзандига тегишли бўлган буюм ва мол-мулк</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">лар ҳамда тегишли мол-мулкларни</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> беришингизни.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Илова:</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#18}Илова ҳужжатлар</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 301.22991689751px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар <span class=\"leading\"></span></span><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">{#7}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 47.135734072022px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 272.90858725762px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style