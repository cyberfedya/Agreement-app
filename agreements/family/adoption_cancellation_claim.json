    "html_format": "<div class=\"document-view-wrapper\">\n<style>\n.html-preview * {font-family: Times New Roman; font-size: 12pt;}\n.html-preview a.NoteRef {text-decoration: none;}\n.html-preview table td {vertical-align: top;}\n.html-preview table {width: 100%;}\n.html-preview p {white-space: pre-wrap;}\n.html-preview .leading {width: 4px; display: inline-block;}\n.html-preview hr {height: 1px; padding: 0; margin: 1em 0; border: 0; border-top: 1px solid #CCC;}\n.html-preview .Normal {className: Normal; margin-bottom: 8pt;}\n.html-preview .ListParagraph {font-family: 'Calibri';}\n.html-preview .ConsPlusNonformat {font-family: 'Courier New'; font-size: 10pt;}\n.html-preview .TableGrid td {border: 1px solid #000;}\n</style>\n<div class=\"html-preview\">\n<style>.html-preview{width: 762px}</style><style>.html-preview{margin-top: 76px}</style><style>.html-preview{margin-bottom: 32px}</style><style>.html-preview{padding-left: 81px}</style><style>.html-preview{padding-right: 57px}</style><table>\n<tr>\n<td 0=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 0=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 6pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Фуқаролик ишлари бўйича </span><span class=\"structures structure-10\" style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">{#10}Ариза берилган фуқаролик суди номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> судига</span></p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 6pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар: </span><span class=\"structures structure-13\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#13}Даъвогарнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">да яшовчи</span></p>\n</td>\n</tr>\n<tr>\n<td 2=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 2=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#14}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n</tr>\n<tr>\n<td 3=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 3=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Телефон: </span><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#15}Даъвогарнинг телефон рақами</span></p>\n</td>\n</tr>\n<tr>\n<td 4=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 4=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Электрон почта манзили: <span class=\"leading\"></span></span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#16}Даъвогарнинг электрон манзили</span></p>\n</td>\n</tr>\n<tr>\n<td 5=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 5=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Жавобгар:</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#18}Жавобгарнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">да яшовчи</span></p>\n</td>\n</tr>\n<tr>\n<td 6=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 6=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 6pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#19}Жавобгарнинг Ф.И.О.си</span></p>\n</td>\n</tr>\n<tr>\n<td 7=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 7=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 6pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Телефон: </span><span class=\"structures structure-20\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#20}Жавобгарнинг телефон рақами</span></p>\n</td>\n</tr>\n<tr>\n<td 8=\"\" style=\" width: 299.56786703601px;\">\n<p> </p>\n</td>\n<td 8=\"\" style=\" width: 321.70637119114px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Электрон почта манзили: <span class=\"leading\"></span></span><span class=\"structures structure-21\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#21}Жавобгарнинг электрон манзили</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъво мазмуни:</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p style=\"text-align: center; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъво ариза </span></p>\n<p> </p>\n<p style=\"text-align: center; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-style: italic;\">(Фарзандликка олишни бекор қилиш юзасидан)</span></p>\n<p> </p>\n<p> </p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-23\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#23}Дастлабки суд иши кўриб чиқилган сана</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> санасида <span class=\"leading\"></span></span><span class=\"structures structure-24\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#24}Ҳал қилув қарорини чиқарган суд номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> судининг ҳал қилув қарори асосида фарзандим </span><span class=\"structures structure-28\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#28}Илова қилинаётган ҳужжатлар рўйхати</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">ни фуқаро </span><span class=\"structures structure-26\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#26}Аризачининг фарзандини фарзандликка олган оила </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">лар оиласи фарзандликка олган. Аммо ҳозирги кунда <span class=\"leading\"></span></span><span class=\"structures structure-26\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#26}Аризачининг фарзандини фарзандликка олган оила </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">лар оиласи фарзандимга нисбатан шафқатсиз муносабатда бўлмоқда.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Ўзбекистон Республикаси Оила кодекси 169-моддасига кўра фарзандликка олинувчиларга нисбатан шафқатсизлик билан муомалада бўлсалар фарзандликка олишни бекор қилиш мумкинлиги кўрсатилган.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Шафқатсиз муносабатда бўлаётганлигиа қуйидагиларни асос қилиб келтираман: <span class=\"leading\"></span></span><span class=\"structures structure-27\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#27}Шафқатсиз муносабат деб аталаётган ҳолатлар</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Қайд қилинган ҳолатлар ва қонун талабидан келиб чиқиб, Ўзбекистон Республикаси Оила кодекси 169, 170-171-моддалари ва </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">Ўзбекистон Республикаси </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Фуқаролик процессуал кодексининг 188, 189-191-моддалари</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">га асосланиб, суддан</span></p>\n<p> </p>\n<p style=\"text-align: center; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000; font-weight: bold;\">СЎРАЙМАН:</span></p>\n<p> </p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">Ф</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">уқаролик ишлари бўйича </span><span class=\"structures structure-24\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#24}Ҳал қилув қарорини чиқарган суд номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> судининг </span><span class=\"structures structure-23\" style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">{#23}Дастлабки суд иши кўриб чиқилган сана</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">даги ҳал қилув қарорини</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> бекор қилишингизни</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> ва фарзандим </span><span class=\"structures structure-25\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#25}Ариза берувчининг фарзандининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">ни ўз қарамоғимга олиб беришингизни.</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Илова:</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span class=\"structures structure-28\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#28}Илова қилинаётган ҳужжатлар рўйхати</span></p>\n<p> </p>\n<p> </p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 18.933333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#14}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 310.6703601108px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">______________</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>(Имзо)</span></p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p> </p>\n<p> </p>\n</td>\n<td 1=\"\" style=\"border: 0; width: 310.6703601108px;\">\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Ариза берилган сана</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p> </p>\n<p> </p>\n<p style=\"text-align: justify; margin-bottom: 0pt;\"></p>\n</div></div>",
