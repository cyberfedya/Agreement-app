    "html_format": "<div class=\"document-view-wrapper\">\n<style>\n.html-preview * {font-family: Times New Roman; font-size: 12pt;}\n.html-preview a.NoteRef {text-decoration: none;}\n.html-preview table td {vertical-align: top;}\n.html-preview table {width: 100%;}\n.html-preview p {white-space: pre-wrap;}\n.html-preview .leading {width: 4px; display: inline-block;}\n.html-preview hr {height: 1px; padding: 0; margin: 1em 0; border: 0; border-top: 1px solid #CCC;}\n.html-preview .Normal {className: Normal; margin-bottom: 8pt;}\n.html-preview .ListParagraph {font-family: 'Times New Roman';}\n.html-preview .ConsPlusNonformat {font-family: 'Courier New'; font-size: 10pt;}\n.html-preview .TableGrid td {border: 1px solid #000;}\n</style>\n<div class=\"html-preview\">\n<style>.html-preview{width: 762px}</style><style>.html-preview{margin-top: 76px}</style><style>.html-preview{margin-bottom: 32px}</style><style>.html-preview{padding-left: 81px}</style><style>.html-preview{padding-right: 57px}</style><table>\n<tr>\n<td 0=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 0=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Фуқаролик ишлари бўйича </span><span class=\"structures structure-2\" style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">{#2}Ариза берилган фуқаролик суди номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> судига</span></p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар: </span><span class=\"structures structure-5\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#5}Даъвогарнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">да яшовчи</span></p>\n</td>\n</tr>\n<tr>\n<td 2=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 2=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#6}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n</tr>\n<tr>\n<td 3=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 3=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Телефон: </span><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#7}Даъвогарнинг телефон рақами</span></p>\n</td>\n</tr>\n<tr>\n<td 4=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 4=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Электрон почта манзили: <span class=\"leading\"></span></span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#8}Даъвогарнинг электрон манзили</span></p>\n</td>\n</tr>\n<tr>\n<td 5=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 5=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Жавобгар: </span><span class=\"structures structure-10\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#10}Жавобгар ташкилотнинг жойлашган манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">да жойлашган</span></p>\n</td>\n</tr>\n<tr>\n<td 6=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 6=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Жавобгар ташкилотнинг номи</span></p>\n</td>\n</tr>\n<tr>\n<td 7=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 7=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Телефон: </span><span class=\"structures structure-12\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#12}Жавобгарнинг телефон рақами</span></p>\n</td>\n</tr>\n<tr>\n<td 8=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 8=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Электрон почта манзили: </span><span class=\"structures structure-13\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#13} Жавобгарнинг электрон манзили</span></p>\n</td>\n</tr>\n<tr>\n<td 9=\"\" style=\" width: 311.86703601108px;\">\n<p> </p>\n</td>\n<td 9=\"\" style=\" width: 324.43213296399px;\">\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъво мазмуни:</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> Иш ҳақимни ундириш юзасидан</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p style=\"text-align: center; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Д<span class=\"leading\"></span>А Ъ В О <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>А Р И З А</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">(Даромадларни эркин тасарруф этиш юзасидан)</span></p>\n<p> </p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">Мен <span class=\"leading\"></span></span><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#15} Даъвогарнинг жавобгар ташкилотда ишлаётган муддати</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> йилдан бери </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Жавобгар ташкилотнинг номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">да </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#16}Даъвогар иш фаолиятини олиб бораётган лавозим номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">лавозимида ишлаб келмоқдаман.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">Менга <span class=\"leading\"></span></span><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#17}Даъвогарга ойлик иш ҳақи берилмаётган муддат </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">дан бери ишлаган барча иш ҳақимни </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Жавобгар ташкилотнинг номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">нинг бош ҳисобчиси </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#18}Жавобгар ташкилотнинг бош ҳисобчиси Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> турли важлар билан бермай келмоқда. </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Жавобгар ташкилотнинг номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">нинг бош ҳисобчиси </span><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#18}Жавобгар ташкилотнинг бош ҳисобчиси Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> дан ойлик иш ҳақимни бермаётганлигини асослантириб беришини сўраганимда мен вояга етмаганлигим сабабли иш ҳақимни бериши мумкинмаслигини важ қилиб келтирди.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Ўзбекистон Республикаси Фуқаролик кодексининг 27-моддасининг 2 қисм 1 бандига кўра вояга етмаганлар ўз иш ҳақи, стипендияси ва бошқа даромадларини эркин тасарруф этиши белгиланган.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 28.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">Юқордигаларга кўра, Ўзбекистон Республикаси Фуқаролик кодексининг 27-моддаси ҳамда Ўзбекистон Республикаси Фуқаролик процессуал кодексининг 188, 189 ва 191-моддаларига асосан,</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">СЎРАЙМАН:</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center; text-indent: 37.8px;\"></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">Менга <span class=\"leading\"></span></span><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#17}Даъвогарга ойлик иш ҳақи берилмаётган муддат </span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\">дан бери ишлаган барча иш ҳақим яъни <span class=\"leading\"></span></span><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#19}Даъвогарнинг ўз вақтида олмаган ойлик иш ҳақи миқдори</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt; color: #000000;\"> сўм маблағларимни </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#11}Жавобгар ташкилотнинг номи</span><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">дан ундириб беришингизни.</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Илова:</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 37.8px;\"><span class=\"structures structure-20\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#20}Илова қилинаётган ҳужжатлар рўйхати</span></p>\n<p> </p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 320.1108033241px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">Даъвогар <span class=\"leading\"></span></span><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#6}Даъвогарнинг Ф.И.О.си</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 94.072022160665px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 207.09141274238px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt; font-weight: bold;\">____________</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\">(Имзо)</span></p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\"border: 0; width: 320.1108033241px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\"border: 0; width: 94.072022160665px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\"border: 0; width: 207.09141274238px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 14pt;\"> </span><span class=\"structures structure-3\" style=\"font-family: 'Times New Roman'; font-size: 14pt;\">{#3}Ариза берилган сана</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p> </p>\n<p> </p>\n</div></div>",
