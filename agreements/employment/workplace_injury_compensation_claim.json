h: 212.07756232687px;\">\n<p> </p>\n</td>\n<td 11=\"\" style=\"border: 0; width: 172.05540166205px;\">\n<p> </p>\n</td>\n<td 11=\"\" style=\"border: 0; width: 252.16620498615px;\">\n<p><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#15}Жавобгарнинг ОКЭД рақами <span class=\"leading\"></span></span></p>\n</td>\n</tr>\n<tr>\n<td 12=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"></p>\n</td>\n<td 12=\"\" style=\"border: 0; width: 172.05540166205px;\">\n<p> </p>\n</td>\n<td 12=\"\" style=\"border: 0; width: 252.16620498615px;\">\n<p><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#16}Жавобгарнинг телефон рақами <span class=\"leading\"></span></span></p>\n</td>\n</tr>\n<tr>\n<td 13=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p> </p>\n</td>\n<td 13=\"\" style=\"border: 0; width: 172.05540166205px;\">\n<p> </p>\n</td>\n<td 13=\"\" style=\"border: 0; width: 252.16620498615px;\">\n<p><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#17}Электрон манзили <span class=\"leading\"></span></span></p>\n</td>\n</tr>\n<tr>\n<td 14=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p> </p>\n</td>\n<td 14=\"\" style=\"border: 0; width: 172.05540166205px;\">\n<p> </p>\n</td>\n<td 14=\"\" style=\"border: 0; width: 252.16620498615px;\">\n<p> </p>\n</td>\n</tr>\n<tr>\n<td 15=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p> </p>\n</td>\n<td 15=\"\" style=\"border: 0; width: 172.05540166205px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">Даъво мазмуни:</span></p>\n</td>\n<td 15=\"\" style=\"border: 0; width: 252.16620498615px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Ишлаб чиқариш жараёнида <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>меҳнатда шикастланганлик учун </span><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#19}Ишлаб чиқариш жараёнида меҳнатда шикастланганлик учун ундирилиши сўралаётган сумма миқдори</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> сўм тўлов ундириш тўғрисида </span></p>\n<p> </p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">ДАЪВО АРИЗА</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Мен </span><span class=\"structures structure-20\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#20}Даъвогар эгаллаб турган вазифасида (лавозимида) қачондан буён ишлаб келётганлиги </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилдан буён </span><span class=\"structures structure-21\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#21}Жавобгар корхона номи </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> корхонасида <span class=\"leading\"></span></span><span class=\"structures structure-22\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#22}Даъвогар ишлаб келган вазифа (лавозим) номи </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> вазифасида ишлаб келганман.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span class=\"tab\" style=\"width: 47.266666666667px; display: inline-block\"></span><span class=\"structures structure-24\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#24}Ишлаб чиқариш жараёнида ходимнинг соғлиғига зарар етказган бахтсиз ходиса содир бўлган вақт (календар</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилда корхонада </span><span class=\"structures structure-25\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#25}Бахтсиз ходисанинг қисқача мазмуни <span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> содир бўлганлиги туфайли соғлиғимга шикаст етди. Натижада мен меҳнат қобилиятимнинг <span class=\"leading\"></span></span><span class=\"structures structure-26\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#26}Бахтсиз ҳодиса <span class=\"leading\"></span>натижасида меҳнат қобилиятининг неча фоизи йўқотилганлиги <span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> фоизини йўқотдим.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span class=\"tab\" style=\"width: 47.266666666667px; display: inline-block\"></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Мазкур ҳолат бўйича <span class=\"leading\"></span></span><span class=\"structures structure-27\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#27}Бахтсиз ҳодиса ва унинг оқибатлари юзасидан қандай ҳужжатлар расмийлаштирилганлиги <span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> каби ҳужжатлар расмийлаштирилган.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span class=\"tab\" style=\"width: 47.266666666667px; display: inline-block\"></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Шундай бўлсада корхона томонидан менинг соғлиғимга етказилган зарарни тўлаш <span class=\"leading\"></span></span><span class=\"structures structure-28\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#28}Соғлиққа етказилган зарар тўланмаслиги сабаблари кўрсатилади <span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> каби сабабларга асосан кечиктирилиб, ижро қилинмасдан келинмоқда.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Ўзбекистон Республикаси Меҳнат кодексининг 322-моддасига кўра, </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">ходимнинг соғлиғига етказилган зиённинг ўрнини иш берувчи томонидан қоплаш қуйидагиларни ўз ичига олади: ходимга бир марталик нафақа тўлаш, ходимга йўқотилган иш ҳақи учун етказилган зиённинг ўрнини қоплаш тарзида амалга ошириладиган ҳар ойлик тўловлар; ходимнинг қўшимча харажатларини компенсация қилиш.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 47.266666666667px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Шунингдек, мазкур кодекснинг 323-моддасига кўра, ходимнинг соғлиғига зиён етказилганлиги муносабати билан иш берувчи томонидан бир йўла тўланадиган нафақа миқдори жамоа шартномасида, агар у тузилмаган бўлса, иш берувчи ва касаба уюшмаси қўмитаси ўртасидаги келишувга биноан белгиланади. Бунда ходимнинг соғлиғига зиён етказилганлиги муносабати билан бир йўла тўланадиган нафақа миқдори жабрланган ходимнинг ўртача ойлик иш ҳақи асосида ҳисобланган йиллик иш ҳақидан кам бўлмаслиги керак.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 47.266666666667px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Мазкур кодекснинг 324-моддасига кўра, ходимнинг соғлиғига зиён етказилганлиги муносабати билан йўқотилган иш ҳақининг ўрнини қоплаш учун амалга ошириладиган ойлик тўловлар миқдори жабрланувчи меҳнатда майиб бўлгунига қадар олган ўртача ойлик иш ҳақига нисбатан унинг касбий меҳнат қобилиятининг йўқотилиши даражасига мувофиқ бўлган фоизли нисбатда белгиланади. Касбий меҳнат қобилиятини йўқотиш даражаси тиббий-ижтимоий эксперт комиссияси томонидан белгиланади.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 47.266666666667px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Зиённинг ўрнини қоплашга оид тўловни тайинлашда жабрланувчи оладиган иш ҳақи, стипендия, пенсия ва бошқа даромадлар ҳисобга олинмайди. Бунда меҳнатда майиб бўлган жабрланганларга — ногиронлиги бўлган шахсларга етказилган зиённинг ўрнини қоплаш суммаси қонунчиликда белгиланган меҳнатга ҳақ тўлаш энг кам миқдорининг эллик фоизидан кам бўлмаслиги керак.</span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span class=\"tab\" style=\"width: 47.266666666667px; display: inline-block\"></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Бугунги кунгача менинг соғлиғимни тиклашга кетган харажатлар </span><span class=\"structures structure-29\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#29}Даъвогар соғлиғига етказилган зарар сўммаси <span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> сўмни ташкил қилади. Даъво талабимга </span><span class=\"structures structure-30\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#30}Даъво талабига асос сифатида келтирилган ҳужжатлар рўйхати ва ишга оид бошқа ҳолатлар</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> каби ҳужжатларни асос сифатида келтираман. </span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span></span><span class=\"tab\" style=\"width: 47.266666666667px; display: inline-block\"></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Юқоридагиларни инобатга олиб, Меҳнат кодексининг 189-моддасига асосан </span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">СЎРАЙМАН:</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 47.266666666667px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">1. Ишлаб чиқариш жараёнида меҳнатда шикастланганлигим учун жавобгардан менинг фойдамга </span><span class=\"structures structure-31\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#31}Жавобгардан ундирилиши сўралаётган сумма </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> сўм миқдорида етказилган зарарни ундириш тўғрисида ҳал қилув қарори чиқаришингизни.</span></p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify; text-indent: 47.266666666667px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Илова: </span><span class=\"structures structure-32\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#32}Даъво аризага илова қилинаётган ҳужжатлар рўйхати </span></p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> <span class=\"leading\"></span></span></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">Даъвогар: <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span></span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: center;\"><span class=\"structures structure-5\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#5}Даъвогарниинг Ф.И.Ш и</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 212.14404432133px;\">\n<p> </p>\n</td>\n</tr>\n<tr>\n<td 1=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p> </p>\n</td>\n<td 1=\"\" style=\"border: 0; width: 212.07756232687px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-style: italic;\">(имзо</span></p>\n</td>\n<td 1=\"\" style=\"border: 0; width: 212.14404432133px;\">\n<p class=\"ConsPlusNonformat\" style=\" text-align: right;\"><span class=\"structures structure-3\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#3}Даъво ариза берилган сана</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p> </p>\n<p class=\"ConsPlusNonformat\" style=\" text-align: justify;\"></p>\n<p> </p>\n</div></div>",
