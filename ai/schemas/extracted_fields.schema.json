{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractedFields",
  "description": "Output of the extraction step: fields already known for a given agreement template, keyed by the template's required_field labels.",
  "type": "object",
  "properties": {
    "agreement_category": { "type": "string" },
    "agreement_template": { "type": "string" },
    "fields": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["agreement_category", "agreement_template", "fields", "missing_fields"]
}
