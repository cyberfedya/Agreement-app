    "html_format": "<div class=\"document-view-wrapper\">\n<style>\n.html-preview * {font-family: Times New Roman; font-size: 12pt;}\n.html-preview a.NoteRef {text-decoration: none;}\n.html-preview table td {vertical-align: top;}\n.html-preview table {width: 100%;}\n.html-preview p {white-space: pre-wrap;}\n.html-preview .leading {width: 4px; display: inline-block;}\n.html-preview hr {height: 1px; padding: 0; margin: 1em 0; border: 0; border-top: 1px solid #CCC;}\n.html-preview .Normal {className: Normal; margin-bottom: 8pt;}\n.html-preview .a3 td {border: 1px solid #000;}\n.html-preview .a4 {className: a4; margin-bottom: 0pt;}\n.html-preview .a6 {className: a6; margin-bottom: 0pt;}\n.html-preview .customClass11 {font-family: 'Arial'; font-size: 10pt;}\n.html-preview .a8 {font-family: 'Courier New'; font-size: 10pt;}\n.html-preview .a9 {font-family: 'Courier New'; font-size: 10pt;}\n.html-preview .aa {className: aa; text-indent: 48px;}\n</style>\n<div class=\"html-preview\">\n<style>.html-preview{width: 762px}</style><style>.html-preview{margin-top: 76px}</style><style>.html-preview{margin-bottom: 32px}</style><style>.html-preview{padding-left: 81px}</style><style>.html-preview{padding-right: 57px}</style><p style=\"text-align: center; margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">ҚАРЗ ШАРТНОМАСИ</span></p>\n<p> </p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 207.02493074792px;\">\n<p style=\"text-align: center;\"><span class=\"structures structure-2\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#2}Шартнома тузилган сана</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> </span></p>\n<p> </p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 207.09141274238px;\">\n<p style=\"text-align: center;\"><span class=\"structures structure-3\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#3}Шартнома рақами</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">-сон</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 207.09141274238px;\">\n<p style=\"text-align: center;\"><span class=\"structures structure-4\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#4}Шартнома тузилган жой</span></p>\n</td>\n</tr>\n</table>\n<p> </p>\n<p> </p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 45.333333333333px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Биз </span><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#6}Қарз берувчининг манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">да яшовчи – </span><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#7}Қарз берувчининг туғилган санаси</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилда туғилган </span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#8}Қарз берувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> (паспорт </span><span class=\"structures structure-9\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#9}Қарз берувчининг паспорт серияси ва рақами</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">,</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> </span><span class=\"structures structure-10\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#10}Қарз берувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">томонидан </span><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#11}Қарз берувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилда берилган) бир томондан (кейинги ўринларда “Қарз берувчи”) ва </span><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#14}Қарз олувчининг манзили</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">да яшовчи – </span><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#15}Қарз олувчининг туғилган санаси</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилда туғилган </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#16}Қарз олувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> (паспорт </span><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#17}Қарз олувчининг паспорт серияси ва рақами</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">,<span class=\"leading\"></span></span><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#18}Қарз олувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> томонидан </span><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#19}Қарз олувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> йилда берилган) (кейинги ўринларда “Қарз олувчи”) иккинчи томондан, ушбу шартномани қуйидагилар ҳақида туздилар.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">1. Шартнома предмети: </span><span class=\"structures structure-22\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#22}Қарз суммаси </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> сўм миқдоридаги пул маблағини қ</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">арз суммаси </span><span class=\"structures structure-25\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#25}фоиз ҳисоблаш шарти билан </span><span class=\"structures structure-26\" style=\"font-family: 'Times New Roman';\">{#26}ф</span><span class=\"structures structure-26\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#26}оизсиз</span><span style=\"font-family: 'Times New Roman';\">.<span class=\"leading\"></span></span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">Қарз олувчи эса ўз зиммасига мазкур маблағни шартномада белгиланган муддатларда қайтариш мажбуриятини олади;</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">1.1.Қарз олувчи эса ҳар ойда қарзнинг тўланмай қолган қисмининг фоизи миқдорида устама тўлайди;</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">1.2. Мазкур шартноманинг 1.1-бандида қайд этилган миқдордаги қарз суммаси Қарз олувчи томонидан Қарз берувчига қисмларга бўлиб қайтарилиши мумкин;</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">1.3. Қарзнинг тўлиқ миқдори </span><span class=\"structures structure-28\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#28}Қарз суммаси қайтарилиши лозим бўлган охирги сана</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">га қадар қайтарилиши шарт.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">2. Томонларнинг ҳуқуқ ва мажбуриятлари:</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">2.1. Қарз берувчи мазкур шартнома имзоланган кундан бошлаб </span><span class=\"structures structure-29\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#29}Қарз берувчи қарз суммасини шартнома имзоланганидан сўнг неча кунда топшириши лозим</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> кун муддат ичида шартноманинг 1.1-бандида кўрсатилган миқдордаги пул маблағини шаклида Қарз олувчига далолатнома асосида тақдим этади. Далолатнома томонлар имзолагандан сўнг мазкур шартноманинг ажралмас қисми ҳисобланади.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">2.2. Қарз олувчи олинган қарз суммасини мазкур шартноманинг 1.3-бандида назарда тутилган муддатга қадар қарз берувчига қайтаради.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">2.3. Қарз берувчи Қарз олувчидан шартнома бўйича берилган қарз суммасини шартномада келишилган муддатдан аввал талаб қилишга </span><span class=\"structures structure-36\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#36}ҳақли эмас</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span class=\"structures structure-35\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#35}2.4. Қарз олувчи қарз берувчи қарзни қайтариш ҳақида талаб қўйган кундан бошлаб </span><span class=\"structures structure-35 structure-37\" style=\"className:35 37; font-family: 'Times New Roman'; font-size: 12pt;\">{#35}Қарз берувчи қарз суммасини муддатдан аввал қайтаришни талаб қилганида қарз олувчи қарзни неча кунда қайтариши керак</span><span class=\"structures structure-35\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#35} кун мобайнида қарзни қайтариши керак. Бундай талаб бўлмаган ҳолларда ҳам Қарз олувчи имкониятидан келиб чиққан ҳолда ҳам қарз суммасини муддатидан аввал <span class=\"leading\"></span>қайтаришга ҳақли.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 45.6px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">3. Томонларнинг жавобгарлиги:</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">3.1. Қарз олувчи ушбу шартноманинг 1.3-бандида назарда тутилган муддатга қадар қарз берувчига қарзни қайтармаса ҳар бир кечиктирилган кун учун қайтарилмаган сумманинг </span><span class=\"structures structure-38\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#38}Қарз суммасини қайтариш кечиктирилганлиги учун ундириладиган бир кунлик пеня миқдори</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> фоиз, лекин қарз суммаси қайтарилмаган қисмининг </span><span class=\"structures structure-39\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#39}Қарз суммасини қайтариш кечиктирилганлиги учун ундириладиган умумий пеня миқдори</span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\"> фоизидан ортиқ бўлмаган миқдорда пеня тўлайди.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4. Шартноманинг бошқа шартлари:</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4.1. Шартнома томонлар имзолаган вақтдан бошлаб кучга киради ва </span><span class=\"structures structure-40\" style=\"font-family: 'Times New Roman'; font-size: 12pt;\">{#40}Шартноманинг амал қилиш муддати </span><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">га қадар амал қилади.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4.2. Қарз олувчи қарз суммасини муддатидан аввал Қарз берувчига қайтарган тақдирда қарз суммаси қарз берувчи томонидан қабул қилиб олинганлиги ҳақида далолатнома имзоланган кунда шартнома бекор бўлган ҳисобланади.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4.3. Мазкур шартнома ва унинг ажралмас қисми ҳисобланган далолатнома икки нусхада тузилди ва бир нусхадан томонларда сақлаш учун берилди.</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4.4. Мазкур шартномага киритиладиган ҳар қандай ўзгартиришлар томонларнинг розилиги асосида қўшимча шартнома тузиш йўли билан амалга оширилади.</span></p>\n<p style=\"text-align: justify; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt;\">4.5. Шартнома юзасидан келиб чиқадиган низолар томонларнинг ўзаро келишуви билан ҳал этилади. Келишувга эришилмаган тақдирда низо шартнома тузилган ҳудуддаги фуқаролик ишлари бўйича судда ҳал этилади.</span></p>\n<p style=\"text-align: center; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-size: 12pt; font-weight: bold;\">Томонларнинг реквизитлари:</span></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-weight: bold;\">Қарз берувчи:</span></p>\n<p><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman';\">{#8}Қарз берувчининг Ф.И.О.си</span></p>\n<p><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman';\">{#6}Қарз берувчининг манзили</span></p>\n<p><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman';\">{#7}Қарз берувчининг туғилган санаси</span><span style=\"font-family: 'Times New Roman';\">да туғилган</span></p>\n<p><span class=\"structures structure-9\" style=\"font-family: 'Times New Roman';\">{#9}Қарз берувчининг паспорт серияси ва рақами</span></p>\n<p><span class=\"structures structure-10\" style=\"font-family: 'Times New Roman';\">{#10}Қарз берувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman';\">туман ИИБ томонидан</span></p>\n<p><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman';\">{#11}Қарз берувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman';\"> йилда берилган</span></p>\n<p><span class=\"structures structure-12\" style=\"font-family: 'Times New Roman';\">{#12}Қарз берувчининг телефон рақами</span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: justify; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-weight: bold;\">Қарз олувчи:</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman';\">{#16}Қарз олувчининг Ф.И.О.си </span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman';\">{#14}Қарз олувчининг манзили</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman';\">{#15}Қарз олувчининг туғилган санаси</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman';\">{#17}Қарз олувчининг паспорт серияси ва рақами</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman';\">{#18}Қарз олувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman';\"> туман ИИБ томонидан</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman';\">{#19}Қарз олувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman';\"> йилда берилган</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-20\" style=\"font-family: 'Times New Roman';\">{#20}Қарз олувчининг телефон рақами</span></p>\n<p style=\"text-align: center;\"></p>\n</td>\n</tr>\n</table>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center; text-indent: 48px;\"></p>\n<p style=\"text-align: center;\"><span style=\"font-family: 'Times New Roman'; font-weight: bold;\">Д<span class=\"leading\"></span>А Л О Л А Т Н О М А</span></p>\n<p style=\"text-align: center;\"><span style=\"font-family: 'Times New Roman';\">(топшириш-қабул қилиш тўғрисида)</span></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: left;\"><span class=\"structures structure-2\" style=\"font-family: 'Times New Roman';\">{#2}Шартнома тузилган сана</span><span style=\"font-family: 'Times New Roman';\"> </span></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: right;\"><span class=\"structures structure-4\" style=\"\">{#4}Шартнома тузилган жой</span><span style=\"font-family: 'Times New Roman';\"> </span></p>\n</td>\n</tr>\n</table>\n<p style=\"text-align: center;\"></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman';\">Биз қуйида далолатнома тузувчилар “Қарз берувчи” </span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman';\">{#8}Қарз берувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> бир томондан ва “Қарз олувчи” </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman';\">{#16}Қарз олувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> иккинчи томондан, гувоҳлар </span><span class=\"structures structure-41\" style=\"font-family: 'Times New Roman';\">{#41}Биринчи гувоҳнинг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> (Манзил: </span><span class=\"structures structure-42\" style=\"font-family: 'Times New Roman';\">{#42}Биринчи гувоҳнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman';\">), </span><span class=\"structures structure-43\" style=\"font-family: 'Times New Roman';\">{#43}Иккинчи гувоҳнинг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> (Манзил: </span><span class=\"structures structure-44\" style=\"font-family: 'Times New Roman';\">{#44}Иккинчи гувоҳнинг яшаш манзили</span>)<span style=\"font-family: 'Times New Roman';\">,<span class=\"leading\"></span></span><span class=\"structures structure-45\" style=\"font-family: 'Times New Roman';\">{#45}Учинчи гувоҳнинг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> (Манзил: </span><span class=\"structures structure-46\" style=\"font-family: 'Times New Roman';\">{#46}Учинчи гувоҳнинг яшаш манзили</span><span style=\"font-family: 'Times New Roman';\">)ларнинг иштирокида ушбу далолатномани қуйидагилар ҳақида туздилар:</span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman';\">Мен “Қарз берувчи” <span class=\"leading\"></span></span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman';\">{#8}Қарз берувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> “Қарз олувчи” </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman';\">{#16}Қарз олувчининг Ф.И.О.си </span><span style=\"font-family: 'Times New Roman';\"> га </span><span class=\"structures structure-22\" style=\"font-family: 'Times New Roman';\">{#22}Қарз суммаси </span><span style=\"font-family: 'Times New Roman';\"> сўм миқдоридаги пул маблағини </span><span class=\"structures structure-49\" style=\"font-family: 'Times New Roman';\">{#49}нақд пул</span><span class=\"structures structure-50\" style=\"font-family: 'Times New Roman';\">{#50}пул кўчириш ёки пластик картага ўтказиш</span><span style=\"font-family: 'Times New Roman';\"> шаклда қарз сифатида топширдим. </span></p>\n<p style=\"text-align: justify; margin-bottom: 0pt; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman';\">Мен “Қарз олувчи ” </span><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman';\">{#16}Қарз олувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\"> “Қарз берувчи” </span><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman';\">{#8}Қарз берувчининг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman';\">дан </span><span class=\"structures structure-22\" style=\"font-family: 'Times New Roman';\">{#22}Қарз суммаси </span><span style=\"font-family: 'Times New Roman';\"> сўм миқдоридаги пул маблағларини </span><span class=\"structures structure-31\" style=\"font-family: 'Times New Roman';\">{#31}нақд пул</span><span style=\"font-family: 'Times New Roman';\"> </span><span class=\"structures structure-32\" style=\"font-family: 'Times New Roman';\">{#32}пул кўчириш ёки пластик картага ўтказиш</span><span style=\"font-family: 'Times New Roman';\"> шаклида қарз сифатида қабул қилиб олдим. </span></p>\n<p style=\"text-align: justify; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman';\">Мазкур далолатнома икки нусхада тузилди ва бир нусхадан томонларда сақлаш учун берилди.</span></p>\n<p style=\"text-align: justify; text-indent: 48px;\"><span style=\"font-family: 'Times New Roman'; font-weight: bold;\">Қарз берувчи:</span><span class=\"tab\" style=\"width: 48px; display: inline-block\"></span><span style=\"font-family: 'Times New Roman'; font-weight: bold;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>Қарз олувчи:</span></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: justify;\"><span class=\"structures structure-8\" style=\"font-family: 'Times New Roman';\">{#8}Қарз берувчининг Ф.И.О.си</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-6\" style=\"font-family: 'Times New Roman';\">{#6}Қарз берувчининг манзили </span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-7\" style=\"font-family: 'Times New Roman';\">{#7}Қарз берувчининг туғилган санаси</span><span style=\"font-family: 'Times New Roman';\">йилда туғилган</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-9\" style=\"font-family: 'Times New Roman';\">{#9}Қарз берувчининг паспорт серияси ва рақами</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-10\" style=\"font-family: 'Times New Roman';\">{#10}Қарз берувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman';\">туман ИИБ томонидан</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-11\" style=\"font-family: 'Times New Roman';\">{#11}Қарз берувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman';\">йилда берилган</span></p>\n<p style=\"text-align: justify;\"></p>\n</td>\n<td 0=\"\" style=\"border: 0; width: 310.60387811634px;\">\n<p style=\"text-align: justify;\"><span class=\"structures structure-16\" style=\"font-family: 'Times New Roman';\">{#16}Қарз олувчининг Ф.И.О.си </span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-14\" style=\"font-family: 'Times New Roman';\">{#14}Қарз олувчининг манзили </span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-15\" style=\"font-family: 'Times New Roman';\">{#15}Қарз олувчининг туғилган санаси</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-17\" style=\"font-family: 'Times New Roman';\">{#17}Қарз олувчининг паспорт серияси ва рақами </span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-18\" style=\"font-family: 'Times New Roman';\">{#18}Қарз олувчига паспортни берган ИИБ номи </span><span style=\"font-family: 'Times New Roman';\"> туман ИИБ томонидан</span></p>\n<p style=\"text-align: justify;\"><span class=\"structures structure-19\" style=\"font-family: 'Times New Roman';\">{#19}Қарз олувчига паспорт берилган сана </span><span style=\"font-family: 'Times New Roman';\">йилда берилган</span></p>\n</td>\n</tr>\n</table>\n<p style=\"text-align: justify;\"></p>\n<table style=\"border: 0px solid; border-spacing: 0; \">\n<tr>\n<td 0=\"\" style=\"border: 0; width: 310.6703601108px;\">\n<p class=\"a8\" style=\" margin-bottom: 0pt;\"><span style=\"font-family: 'Times New Roman'; font-size: 11pt; font-weight: bold;\">Гувоҳлар:</span><span style=\"font-family: 'Times New Roman'; font-size: 11pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span></span><span class=\"structures structure-41\" style=\"font-family: 'Times New Roman'; font-size: 11pt;\">{#41}Биринчи гувоҳнинг Ф.И.О.си</span><span style=\"font-family: 'Times New Roman'; font-size: 11pt;\"> <span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span><span class=\"leading\"></span>____